node_modules
dist

# ignore all build files except for the .desktop and PKGBUILD files
build/linux/arch/*
!build/linux/arch/PKGBUILD
!build/linux/arch/.SRCINFO
!build/linux/arch/tidal-hifi.desktop
!build/linux/arch/install.sh
*.css
*.css.map

# JetBrains IDE configuration
.idea
ts-dist/**
ts-dist
themes
!src/themes
.sass-cache
html-exports

# Local multi-scrobbler runtime and secrets
multi-scrobbler-setup/.tidal-hifi-token
multi-scrobbler-setup/secrets/*
multi-scrobbler-setup/data/*
multi-scrobbler-setup/logs/*
!multi-scrobbler-setup/secrets/.gitkeep
!multi-scrobbler-setup/secrets/*.example
!multi-scrobbler-setup/data/.gitkeep
!multi-scrobbler-setup/logs/.gitkeep
